# Neon Postgres
DATABASE_URL=                    # Pooled connection string (PgBouncer) — API routes
DATABASE_URL_UNPOOLED=           # Direct connection — migrations, background jobs

# AI
AI_GATEWAY_API_KEY=              # Vercel AI Gateway — routes to OpenAI/Anthropic, billing via Vercel
ANTHROPIC_API_KEY=               # Claude Sonnet 4.6 — schema mapping, NL search, outreach, hallucination checks
# OPENAI_API_KEY=                # Optional — only if not using AI Gateway for embeddings

# Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Storage
BLOB_READ_WRITE_TOKEN=           # Vercel Blob — stores original CSVs (private, audit trail)

# Cron
CRON_SECRET=                     # Random secret — verified in cron route handlers
