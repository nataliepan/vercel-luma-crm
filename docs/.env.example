# Copy to .env.local and fill in your values

# Neon Postgres — get both from your Neon project dashboard
DATABASE_URL=                        # Pooled connection string (PgBouncer) — used by API routes
DATABASE_URL_UNPOOLED=               # Direct connection string — used by background jobs

# OpenAI — for text-embedding-3-small (contact embeddings)
OPENAI_API_KEY=

# Anthropic — for claude-sonnet-4-6 (schema mapping, NL search, outreach drafting)
ANTHROPIC_API_KEY=

# Clerk — get from clerk.com dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Vercel Blob — get from your Vercel project Storage tab
BLOB_READ_WRITE_TOKEN=

# Cron secret — any random string, set the same value in Vercel env vars
# Vercel automatically sets Authorization: Bearer <CRON_SECRET> on cron requests
CRON_SECRET=
